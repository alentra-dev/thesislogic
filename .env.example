# ThesisLogic configuration — copy to your EnvironmentFile / shell profile.

# Storage
THESISLOGIC_DATA_DIR=./data
THESISLOGIC_PACKS_DIR=./packs
THESISLOGIC_ACTIVE_PACK=            # empty = first installed pack

# Server
THESISLOGIC_HOST=127.0.0.1
THESISLOGIC_PORT=8600
THESISLOGIC_FIRM_NAME=Your Firm

# AI posture: none | openai_compatible (local servers) | anthropic | openai | gemini
THESISLOGIC_GENERATION_PROVIDER=none
THESISLOGIC_GENERATION_BASE_URL=http://127.0.0.1:8080   # local servers only; cloud providers default correctly
THESISLOGIC_GENERATION_MODEL=       # defaults: claude-opus-4-8 / gpt-4o / gemini-2.5-pro per provider
THESISLOGIC_GENERATION_API_KEY=     # or the vendor variable: ANTHROPIC_API_KEY / OPENAI_API_KEY / GEMINI_API_KEY
THESISLOGIC_GENERATION_MAX_TOKENS=2400
# Character budget for the evidence section of generation prompts — protects
# small per-slot context windows on local servers.
THESISLOGIC_GENERATION_PROMPT_BUDGET=7000
# Corrective retries when the proof gate rejects a live draft.
THESISLOGIC_GENERATION_GATE_RETRIES=1
# false = shadow mode: attorneys always get the deterministic answer; live
# output is recorded in the audit trail only. Recommended for rollout.
THESISLOGIC_PREFER_LIVE_OUTPUT=true

# Embeddings (optional): none | openai_compatible | openai
THESISLOGIC_EMBEDDING_PROVIDER=none
THESISLOGIC_EMBEDDING_BASE_URL=http://127.0.0.1:8092
THESISLOGIC_EMBEDDING_MODEL=        # openai default: text-embedding-3-small

# Auth
THESISLOGIC_ALLOW_REGISTRATION=true   # set false after the first admin exists
THESISLOGIC_SESSION_TTL_SECONDS=28800
